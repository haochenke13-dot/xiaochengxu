/* 设备列表页UI优化 */

/* 简约蓝色设备图标 */
.hero-visual {
  background:
    radial-gradient(circle at 22% 22%, rgba(110, 231, 183, 0.22), transparent 28%),
    radial-gradient(circle at 78% 72%, rgba(56, 189, 248, 0.18), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(236, 253, 245, 0.74));
  border: 1rpx solid rgba(167, 243, 208, 0.84);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84),
    0 10rpx 20rpx rgba(16, 185, 129, 0.06);
}

.hero-scene-grid,
.hero-scene-glow,
.device-signal-ring,
.device-hub-panel,
.device-hub-panel-dot,
.device-hub-panel-line,
.device-hub-panel-chip,
.device-hub-shell,
.device-hub-antenna,
.device-hub-head,
.device-hub-lens,
.device-hub-light,
.device-hub-screen,
.device-hub-grid,
.device-hub-bar,
.device-hub-pulse,
.device-hub-base,
.device-hub-metrics {
  position: absolute;
}

.hero-scene-grid {
  opacity: 0.44;
}

.hero-scene-grid-h {
  left: 18rpx;
  right: 18rpx;
  top: 22rpx;
  bottom: 22rpx;
  background: linear-gradient(rgba(20, 184, 166, 0.08) 2rpx, transparent 2rpx);
  background-size: 100% 28rpx;
}

.hero-scene-grid-v {
  left: 28rpx;
  right: 28rpx;
  top: 18rpx;
  bottom: 18rpx;
  background: linear-gradient(90deg, rgba(14, 165, 233, 0.08) 2rpx, transparent 2rpx);
  background-size: 28rpx 100%;
}

.hero-scene-glow {
  border-radius: 50%;
}

.device-scene-glow-a {
  width: 122rpx;
  height: 122rpx;
  left: 8rpx;
  top: 8rpx;
  background: radial-gradient(circle, rgba(110, 231, 183, 0.2), transparent 72%);
}

.device-scene-glow-b {
  width: 144rpx;
  height: 144rpx;
  right: 0;
  bottom: -6rpx;
  background: radial-gradient(circle, rgba(56, 189, 248, 0.18), transparent 72%);
}

.device-signal-ring {
  left: 50%;
  top: 48%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.device-signal-ring-a {
  width: 122rpx;
  height: 122rpx;
  border: 3rpx solid rgba(56, 189, 248, 0.2);
}

.device-signal-ring-b {
  width: 158rpx;
  height: 158rpx;
  border: 2rpx dashed rgba(45, 212, 191, 0.18);
}

.device-hub-panel {
  width: 64rpx;
  height: 48rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(186, 230, 253, 0.82);
  box-shadow:
    0 10rpx 18rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.device-hub-panel-a {
  left: 22rpx;
  top: 26rpx;
}

.device-hub-panel-b {
  right: 18rpx;
  bottom: 20rpx;
}

.device-hub-panel-dot {
  left: 12rpx;
  top: 14rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.92), rgba(6, 182, 212, 0.82));
  box-shadow: 0 0 0 4rpx rgba(110, 231, 183, 0.14);
}

.device-hub-panel-line {
  left: 32rpx;
  right: 12rpx;
  top: 16rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.32);
}

.device-hub-panel-line-short {
  top: 28rpx;
  right: 22rpx;
  background: rgba(20, 184, 166, 0.3);
}

.device-hub-panel-chip {
  left: 12rpx;
  top: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, rgba(14, 165, 233, 0.88), rgba(20, 184, 166, 0.72));
}

.device-hub-panel-bars {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
}

.device-hub-panel-bars view {
  width: 7rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(14, 165, 233, 0.88), rgba(16, 185, 129, 0.52));
}

.device-hub-panel-bars view:nth-child(1) {
  height: 12rpx;
}

.device-hub-panel-bars view:nth-child(2) {
  height: 18rpx;
}

.device-hub-panel-bars view:nth-child(3) {
  height: 24rpx;
}

.device-hub-shell {
  left: 50%;
  top: 50%;
  width: 124rpx;
  height: 142rpx;
  transform: translate(-50%, -58%);
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(237, 252, 247, 0.92));
  border: 1rpx solid rgba(186, 230, 253, 0.88);
  box-shadow:
    0 16rpx 26rpx rgba(14, 165, 233, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
  z-index: 3;
}

.device-hub-antenna {
  left: 50%;
  top: -14rpx;
  width: 6rpx;
  height: 22rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(14, 165, 233, 0.88), rgba(20, 184, 166, 0.6));
}

.device-hub-head {
  left: 20rpx;
  right: 20rpx;
  top: 16rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.device-hub-lens {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 38%, rgba(255, 255, 255, 0.94), rgba(186, 230, 253, 0.72) 40%, rgba(14, 165, 233, 0.7) 72%, rgba(8, 47, 73, 0.78) 100%);
  box-shadow: 0 0 0 6rpx rgba(56, 189, 248, 0.08);
}

.device-hub-light {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(167, 243, 208, 0.9);
}

.device-hub-light-a {
  box-shadow: 0 0 0 4rpx rgba(16, 185, 129, 0.08);
}

.device-hub-light-b {
  background: rgba(125, 211, 252, 0.92);
  box-shadow: 0 0 0 4rpx rgba(14, 165, 233, 0.08);
}

.device-hub-screen {
  left: 16rpx;
  right: 16rpx;
  top: 52rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(240, 253, 250, 0.98), rgba(224, 242, 254, 0.96));
  border: 1rpx solid rgba(167, 243, 208, 0.82);
  overflow: hidden;
}

.device-hub-grid {
  left: 12rpx;
  right: 12rpx;
  height: 2rpx;
  background: rgba(148, 163, 184, 0.16);
}

.device-hub-grid-a {
  top: 16rpx;
}

.device-hub-grid-b {
  bottom: 14rpx;
}

.device-hub-bar {
  bottom: 10rpx;
  width: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(14, 165, 233, 0.84), rgba(16, 185, 129, 0.5));
}

.device-hub-bar-a {
  left: 18rpx;
  height: 18rpx;
}

.device-hub-bar-b {
  left: 34rpx;
  height: 28rpx;
}

.device-hub-bar-c {
  left: 50rpx;
  height: 38rpx;
}

.device-hub-pulse {
  right: 14rpx;
  top: 14rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(16, 185, 129, 0.94);
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.08);
}

.device-hub-base {
  left: 50%;
  bottom: 22rpx;
  width: 22rpx;
  height: 14rpx;
  transform: translateX(-50%);
  border-radius: 0 0 10rpx 10rpx;
  background: linear-gradient(180deg, rgba(186, 230, 253, 0.9), rgba(148, 163, 184, 0.64));
}

.device-hub-metrics {
  left: 24rpx;
  right: 24rpx;
  bottom: 6rpx;
  display: flex;
  gap: 8rpx;
}

.device-hub-metrics view {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(14, 165, 233, 0.72), rgba(16, 185, 129, 0.44));
}

.device-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
}

.device-body {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #3B82F6, #0EA5E9);
  border-radius: 24rpx;
  box-shadow:
    0 8rpx 32rpx rgba(14, 165, 233, 0.3),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.2);
}

.device-screen-simple {
  position: absolute;
  left: 50%;
  top: 45%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 0 rgba(14, 165, 233, 0.1);
}

.device-screen-simple::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  border-radius: 50%;
  opacity: 0.3;
}

.device-screen-simple::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(14, 165, 233, 0.5);
}

.device-base {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 12rpx;
  background: rgba(148, 163, 184, 0.3);
  border-radius: 6rpx;
}

.device-light {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #22C55E;
  border-radius: 50%;
  box-shadow: 0 0 8rpx rgba(34, 197, 94, 0.6);
}

.device-light-a {
  top: 30rpx;
  right: 30rpx;
  animation: pulse-light 2s ease-in-out infinite;
}

.device-light-b {
  bottom: 30rpx;
  left: 30rpx;
  animation: pulse-light 2s ease-in-out infinite 1s;
}

@keyframes pulse-light {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(0.9);
  }
}

/* 优化设备卡片 */
.device-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.device-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 优化设备标题 */
.device-title-wrap {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

/* 优化设备元数据网格 */
.device-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F1F5F9;
}

.device-meta-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 4rpx;
}

.device-meta-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.device-grid-full {
  grid-column: 1 / -1;
}

/* 优化状态徽章 */
.device-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.device-status-badge.running {
  background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
  color: #065F46;
}

.device-status-badge.warning {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  color: #92400E;
}

.device-status-badge.offline {
  background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
  color: #64748B;
}

/* 优化筛选行 */
.device-filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  scrollbar-width: none;
}

.filter-chip {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #F1F5F9;
  color: #64748B;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.filter-chip.active {
  background: linear-gradient(135deg, #10B981, #059669);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.25);
}

/* 优化设备摘要网格 */
.device-summary-grid {
  margin-top: 20rpx;
}

.device-kpi-ribbon {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

/* 优化空状态 */
.empty {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

/* 优化分组标题 */
.device-group-gap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F1F5F9;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}
