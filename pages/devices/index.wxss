/* 设备列表页UI优化 */

/* 优化设备卡片 */
.device-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.device-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 优化设备标题 */
.device-title-wrap {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

/* 优化设备元数据网格 */
.device-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F1F5F9;
}

.device-meta-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 4rpx;
}

.device-meta-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.device-grid-full {
  grid-column: 1 / -1;
}

/* 优化状态徽章 */
.device-status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.device-status-badge.running {
  background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
  color: #065F46;
}

.device-status-badge.warning {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  color: #92400E;
}

.device-status-badge.offline {
  background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
  color: #64748B;
}

/* 优化筛选行 */
.device-filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  scrollbar-width: none;
}

.filter-chip {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #F1F5F9;
  color: #64748B;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.filter-chip.active {
  background: linear-gradient(135deg, #10B981, #059669);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.25);
}

/* 优化设备摘要网格 */
.device-summary-grid {
  margin-top: 20rpx;
}

.device-kpi-ribbon {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

/* 优化空状态 */
.empty {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

/* 优化分组标题 */
.device-group-gap {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F1F5F9;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}
