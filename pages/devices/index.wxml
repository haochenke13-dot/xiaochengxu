<view class="page-shell">
  <view class="page-body">
    <view class="hero-card hero-mint section">
      <view class="hero-layout">
        <view class="hero-copy">
          <view class="hero-title">{{texts.title}}</view>
          <view class="hero-desc">{{texts.desc}}</view>
          <view class="kpi-ribbon device-kpi-ribbon">
            <view class="kpi-chip">
              <view class="kpi-code">{{texts.total}}</view>
              <view class="kpi-value">{{summary.total}}</view>
            </view>
            <view class="kpi-chip">
              <view class="kpi-code">{{texts.alert}}</view>
              <view class="kpi-value">{{summary.warning}}</view>
            </view>
            <view class="kpi-chip">
              <view class="kpi-code">{{texts.offline}}</view>
              <view class="kpi-value">{{summary.offline}}</view>
            </view>
          </view>
        </view>
        <view class="hero-visual">
          <view class="device-icon">
            <view class="device-body"></view>
            <view class="device-screen-simple"></view>
            <view class="device-base"></view>
            <view class="device-light device-light-a"></view>
            <view class="device-light device-light-b"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="card">
        <view class="group-title">{{texts.filter}}</view>
        <view class="chip-row device-filter-row">
          <block wx:for="{{statusFilters}}" wx:key="key">
            <view class="chip {{currentStatus === item.key ? 'chip-active' : ''}}" data-status="{{item.key}}" bindtap="changeStatus">{{item.name}}</view>
          </block>
        </view>
        <view class="group-title device-group-gap">{{texts.type}}</view>
        <view class="chip-row">
          <block wx:for="{{typeFilters}}" wx:key="key">
            <view class="chip {{currentType === item.key ? 'chip-active' : ''}}" data-type="{{item.key}}" bindtap="changeType">{{item.name}}</view>
          </block>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="list" wx:if="{{devices.length}}">
        <block wx:for="{{devices}}" wx:key="deviceId">
          <view class="card device-card" data-id="{{item.deviceId}}" bindtap="openDetail">
            <view class="row-between">
              <view class="art-row device-title-wrap">
                <view class="art-pill art-pill-ring"></view>
                <view>
                  <view class="value">{{item.name}}</view>
                  <view class="section-subtitle">{{item.type}}</view>
                </view>
              </view>
              <view class="badge {{item.statusMeta.className}}">{{item.statusMeta.text}}</view>
            </view>
            <view class="device-meta-grid">
              <view>
                <view class="label">{{texts.loc}}</view>
                <view class="value device-meta-value">{{item.location}}</view>
              </view>
              <view>
                <view class="label">{{texts.run}}</view>
                <view class="value device-meta-value">{{item.runtime}}</view>
              </view>
              <view class="device-grid-full">
                <view class="label">{{texts.hb}}</view>
                <view class="value device-meta-value">{{item.lastHeartbeat}}</view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="empty" wx:else>{{texts.empty}}</view>
    </view>
  </view>
</view>
