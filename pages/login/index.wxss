/* 登录页：背景图为浅色时保持底图颜色，勿叠深色渐变/遮罩 */
.login-shell {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #ffffff;
}

.login-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.login-body {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
  padding: 48rpx 24rpx 120rpx;
  box-sizing: border-box;
}

/* 卡片顶部 logo（压缩纵向占位，让卡片上下更紧凑） */
.card-logo {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 22rpx;
  position: relative;
  min-height: 168rpx;
}

.logo-img {
  width: 188rpx;
  height: 188rpx;
  position: relative;
  z-index: 1;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx;
  box-sizing: border-box;
  box-shadow:
    0 14rpx 36rpx rgba(15, 23, 42, 0.16),
    0 0 0 10rpx rgba(255, 255, 255, 0.22);
}

.logo-text {
  font-size: 132rpx;
  line-height: 1;
  opacity: 0.85;
  position: relative;
  z-index: 1;
}

/* Logo 光晕装饰 */
.card-logo::before {
  content: '';
  position: absolute;
  width: 236rpx;
  height: 236rpx;
  background: radial-gradient(
    circle,
    rgba(59, 130, 246, 0.24) 0%,
    rgba(14, 165, 233, 0.14) 42%,
    rgba(16, 185, 129, 0.08) 62%,
    transparent 76%
  );
  border-radius: 50%;
  z-index: 0;
}

.card-logo::after {
  content: '';
  position: absolute;
  width: 262rpx;
  height: 262rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  z-index: 0;
}

/* 登录卡片：保持原宽度，纵向压缩；白底 50% 不透明度 */
.login-card {
  position: relative;
  z-index: 1;
  width: 600rpx;
  margin-top: -24rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    0 8rpx 40rpx rgba(0, 0, 0, 0.1),
    0 2rpx 12rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
  padding: 34rpx 40rpx 30rpx;
  animation: cardFadeIn 0.5s ease-out;
}

@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 18rpx;
}

.role-picker {
  width: 100%;
}

.picker-value {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(59, 130, 246, 0.22);
  border-radius: 20rpx;
  padding: 0 20rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1e293b;
  transition: all 0.2s ease;
}

.picker-value-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
  justify-content: flex-start;
  height: 88rpx;
}

/* 用 view + 与行同高 line-height，避免 text 组件基线导致比箭头偏下 */
.picker-value-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  line-height: 88rpx;
  height: 88rpx;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-value:active {
  border-color: rgba(59, 130, 246, 0.45);
  background: rgba(255, 255, 255, 0.98);
}

.picker-value .placeholder {
  color: #94a3b8;
}

.picker-value-arrow {
  flex-shrink: 0;
  width: 40rpx;
  height: 88rpx;
  font-size: 34rpx;
  line-height: 88rpx;
  text-align: center;
  color: #3b82f6;
  font-weight: 300;
}

.role-desc {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(59, 130, 246, 0.08);
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #3b82f6;
}

.desc-icon {
  font-size: 28rpx;
  font-weight: 700;
}

.login-btn {
  width: 100%;
  background: linear-gradient(135deg, #3b82f6 0%, #0ea5e9 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
  box-shadow:
    0 8rpx 24rpx rgba(59, 130, 246, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow:
    0 4rpx 16rpx rgba(59, 130, 246, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

.login-btn[disabled] {
  background: #e2e8f0;
  color: #94a3b8;
  box-shadow: none;
}

.footer-tip {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  z-index: 2;
}
