/* ===== 通用样式 ===== */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 32rpx;
  gap: 24rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.1), rgba(59, 130, 246, 0.05));
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.empty-icon::before {
  content: '';
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.3), rgba(59, 130, 246, 0.2));
  border-radius: 12rpx;
  transform: rotate(15deg);
}

.empty-icon::after {
  content: '';
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.5), rgba(59, 130, 246, 0.4));
  border-radius: 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
  font-weight: 500;
}
