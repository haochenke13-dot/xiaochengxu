<view class="page-shell">
  <view class="page-body materials-page">
    <!-- 顶部系列选择器 -->
    <view class="top-section">
      <view class="section-title">{{texts.series}}</view>
      <view class="series-selector">
        <block wx:for="{{seriesList}}" wx:key="id">
          <view class="series-item {{selectedSeries === item.id ? 'series-active' : ''}}"
                data-series="{{item.id}}"
                bindtap="onSeriesChange">
            <view class="series-icon series-icon-{{item.id}}"></view>
            <view class="series-name">{{locale === 'zh' ? item.name : item.nameEn}}</view>
          </view>
        </block>
      </view>
    </view>

    <!-- 型号选择器 -->
    <view class="models-section" wx:if="{{modelsList.length > 0}}">
      <view class="model-header">
        <view class="section-title-small">{{texts.selectModel}}</view>
        <view class="slide-hint">{{locale === 'zh' ? '← 查看更多' : 'See more ←'}}</view>
      </view>
      <view class="model-scroll">
        <block wx:for="{{modelsList}}" wx:key="id">
          <view class="model-item {{selectedModel === item.id ? 'model-active' : ''}}"
                data-model="{{item.id}}"
                bindtap="onModelChange">
            <view class="model-image-wrapper">
              <image class="model-image" src="/assets/models/{{item.id}}.png" mode="aspectFit"></image>
            </view>
            <view class="model-name">{{locale === 'zh' ? item.name : item.nameEn}}</view>
          </view>
        </block>
      </view>
    </view>

    <!-- 底部区域：类别侧边栏 + 零件列表 -->
    <view class="bottom-section" wx:if="{{materials.length > 0}}">
      <!-- 类别侧边栏 -->
      <view class="category-sidebar">
        <block wx:for="{{categoriesList}}" wx:key="key">
          <view class="category-item {{selectedCategory === item.key ? 'category-active' : ''}}"
                data-category="{{item.key}}"
                bindtap="onCategoryChange">
            <view class="category-icon category-{{item.key}}"></view>
            <view class="category-name">{{item.name}}</view>
            <view class="category-count">{{item.count}}</view>
          </view>
        </block>
      </view>

      <!-- 零件列表 -->
      <view class="parts-content">
        <view class="parts-grid">
          <block wx:for="{{filteredMaterials}}" wx:key="materialId">
            <view class="part-card">
              <view class="part-image-wrapper">
                <image class="part-image" src="/assets/parts/{{item.materialId}}.png" mode="aspectFit"></image>
              </view>
              <view class="part-info">
                <view class="part-name">{{item.name}}</view>
                <view class="part-spec">{{item.spec}}</view>
                <view class="part-price">{{item.price}}</view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{selectedSeries && selectedModel && materials.length === 0}}">
      <view class="empty-icon"></view>
      <view class="empty-text">{{texts.empty}}</view>
    </view>
  </view>
</view>
