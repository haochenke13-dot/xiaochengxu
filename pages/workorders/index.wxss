/* 工单列表页UI优化 */

/* 工单队列图案（与首页一致） */
.hero-visual {
  background:
    radial-gradient(circle at 18% 24%, rgba(196, 181, 253, 0.24), transparent 28%),
    radial-gradient(circle at 78% 74%, rgba(129, 140, 248, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(248, 243, 255, 0.72));
  border: 1rpx solid rgba(221, 214, 254, 0.88);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84),
    0 10rpx 20rpx rgba(139, 92, 246, 0.06);
}

.hero-scene-grid,
.hero-scene-glow,
.workorder-flow-card,
.workorder-flow-topbar,
.workorder-flow-status,
.workorder-flow-step,
.workorder-flow-node,
.workorder-flow-line,
.workorder-flow-chip,
.workorder-flow-dot,
.workorder-float,
.workorder-float-core,
.workorder-float-pill,
.workorder-curve,
.workorder-curve-dot {
  position: absolute;
}

.hero-scene-grid {
  opacity: 0.46;
}

.hero-scene-grid-h {
  left: 18rpx;
  right: 18rpx;
  top: 24rpx;
  bottom: 24rpx;
  background: linear-gradient(rgba(139, 92, 246, 0.08) 2rpx, transparent 2rpx);
  background-size: 100% 28rpx;
}

.hero-scene-grid-v {
  left: 28rpx;
  right: 28rpx;
  top: 18rpx;
  bottom: 18rpx;
  background: linear-gradient(90deg, rgba(129, 140, 248, 0.08) 2rpx, transparent 2rpx);
  background-size: 28rpx 100%;
}

.hero-scene-glow {
  border-radius: 50%;
}

.workorder-scene-glow-a {
  width: 104rpx;
  height: 104rpx;
  left: 16rpx;
  top: 16rpx;
  background: radial-gradient(circle, rgba(196, 181, 253, 0.22), transparent 70%);
}

.workorder-scene-glow-b {
  width: 136rpx;
  height: 136rpx;
  right: 4rpx;
  bottom: 0;
  background: radial-gradient(circle, rgba(129, 140, 248, 0.18), transparent 72%);
}

.workorder-flow-card {
  border-radius: 24rpx;
}

.workorder-flow-card-back {
  left: 58rpx;
  top: 38rpx;
  width: 116rpx;
  height: 130rpx;
  background: rgba(196, 181, 253, 0.18);
  border: 1rpx solid rgba(221, 214, 254, 0.6);
  transform: rotate(-11deg);
}

.workorder-flow-card-mid {
  left: 74rpx;
  top: 28rpx;
  width: 122rpx;
  height: 138rpx;
  background: rgba(224, 231, 255, 0.28);
  border: 1rpx solid rgba(199, 210, 254, 0.68);
  transform: rotate(-4deg);
}

.workorder-flow-card-front {
  left: 50%;
  top: 50%;
  width: 128rpx;
  height: 148rpx;
  transform: translate(-50%, -56%);
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 243, 255, 0.94));
  border: 1rpx solid rgba(196, 181, 253, 0.82);
  box-shadow:
    0 14rpx 24rpx rgba(139, 92, 246, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  z-index: 3;
}

.workorder-flow-topbar {
  left: 16rpx;
  right: 42rpx;
  top: 16rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(124, 58, 237, 0.88), rgba(129, 140, 248, 0.7));
}

.workorder-flow-status {
  right: 16rpx;
  top: 14rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(167, 139, 250, 0.94), rgba(124, 58, 237, 0.82));
  box-shadow: 0 0 0 6rpx rgba(167, 139, 250, 0.14);
}

.workorder-flow-step {
  left: 16rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.workorder-flow-step-a {
  top: 46rpx;
}

.workorder-flow-step-b {
  top: 78rpx;
}

.workorder-flow-step-c {
  top: 112rpx;
  gap: 8rpx;
}

.workorder-flow-node {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.92), rgba(129, 140, 248, 0.76));
  box-shadow: 0 0 0 6rpx rgba(196, 181, 253, 0.16);
  flex-shrink: 0;
}

.workorder-flow-node-soft {
  background: linear-gradient(180deg, rgba(167, 139, 250, 0.72), rgba(196, 181, 253, 0.64));
}

.workorder-flow-line {
  flex: 1;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(196, 181, 253, 0.18), rgba(129, 140, 248, 0.66));
}

.workorder-flow-line-short {
  max-width: 26rpx;
}

.workorder-flow-chip {
  width: 34rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(129, 140, 248, 0.28);
  flex-shrink: 0;
}

.workorder-flow-chip-wide {
  width: 40rpx;
}

.workorder-flow-chip-mid {
  width: 40rpx;
}

.workorder-flow-chip-short {
  width: 22rpx;
  background: rgba(167, 139, 250, 0.24);
}

.workorder-flow-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(124, 58, 237, 0.7);
  box-shadow: 0 0 0 4rpx rgba(196, 181, 253, 0.16);
  flex-shrink: 0;
}

.workorder-float {
  border-radius: 50%;
}

.workorder-float-a {
  left: 28rpx;
  bottom: 28rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(221, 214, 254, 0.92);
  box-shadow: 0 8rpx 14rpx rgba(129, 140, 248, 0.1);
}

.workorder-float-core {
  left: 50%;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.88), rgba(167, 139, 250, 0.76));
}

.workorder-float-b {
  right: 30rpx;
  top: 34rpx;
  width: 18rpx;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(196, 181, 253, 0.84);
}

.workorder-float-pill {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(196, 181, 253, 0.34);
}

.workorder-float-pill-a {
  left: 22rpx;
  top: 40rpx;
  width: 42rpx;
}

.workorder-float-pill-b {
  right: 20rpx;
  bottom: 26rpx;
  width: 36rpx;
  background: rgba(129, 140, 248, 0.28);
}

.workorder-curve {
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(196, 181, 253, 0.08), rgba(129, 140, 248, 0.52), rgba(196, 181, 253, 0.08));
}

.workorder-curve-a {
  left: 34rpx;
  top: 58rpx;
  width: 60rpx;
  transform: rotate(-26deg);
}

.workorder-curve-b {
  right: 22rpx;
  bottom: 52rpx;
  width: 68rpx;
  transform: rotate(26deg);
}

.workorder-curve-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(129, 140, 248, 0.74);
}

.workorder-curve-dot-a {
  left: 80rpx;
  top: 42rpx;
}

.workorder-curve-dot-b {
  right: 72rpx;
  bottom: 34rpx;
}

.queue-stack {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 100rpx;
  border-radius: 8rpx;
  z-index: 1;
}

.queue-back {
  background: rgba(191, 219, 254, 0.45);
  border: 2rpx solid rgba(147, 197, 253, 0.65);
  transform: translate(-50%, -50%) rotate(-6deg) translate(12rpx, 8rpx);
}

.queue-mid {
  background: rgba(147, 197, 253, 0.55);
  border: 2rpx solid rgba(96, 165, 250, 0.75);
  transform: translate(-50%, -50%) rotate(3deg) translate(-8rpx, -4rpx);
  z-index: 2;
}

.queue-sheet {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12rpx;
  border: 3rpx solid rgba(96, 165, 250, 0.85);
  box-shadow:
    0 8rpx 24rpx rgba(37, 99, 235, 0.15),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9);
  z-index: 3;
  overflow: hidden;
}

.queue-sheet-top {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  height: 16rpx;
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.85), rgba(59, 130, 246, 0.75));
  border-radius: 6rpx;
}

.queue-bullet {
  position: absolute;
  top: 40rpx;
  left: 16rpx;
  width: 12rpx;
  height: 12rpx;
  background: rgba(239, 68, 68, 0.85);
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(239, 68, 68, 0.25);
}

.queue-line {
  position: absolute;
  left: 36rpx;
  height: 6rpx;
  background: rgba(148, 163, 184, 0.4);
  border-radius: 3rpx;
}

.queue-line-a {
  top: 38rpx;
  width: 68rpx;
}

.queue-line-b {
  top: 52rpx;
  width: 52rpx;
}

.queue-line-c {
  top: 66rpx;
  width: 76rpx;
}

/* 工单操作区域布局 */
.workorders-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
}

.workorders-workflow {
  flex: 1;
}

.workorders-create-btn {
  min-width: 200rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.3);
  padding: 0 24rpx;
}

.workorders-create-btn::after {
  border: none;
}

.workorders-create-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(14, 165, 233, 0.2);
}

.workorder-doc-frame {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 140rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.45);
  border: 2rpx solid rgba(191, 219, 254, 0.65);
}

.workorder-doc-corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  z-index: 4;
}

.workorder-doc-corner-tl {
  left: 8rpx;
  top: 8rpx;
  border-left: 5rpx solid rgba(59, 130, 246, 0.92);
  border-top: 5rpx solid rgba(59, 130, 246, 0.92);
  border-top-left-radius: 18rpx;
}

.workorder-doc-corner-tr {
  right: 8rpx;
  top: 8rpx;
  border-right: 5rpx solid rgba(34, 197, 213, 0.92);
  border-top: 5rpx solid rgba(34, 197, 213, 0.92);
  border-top-right-radius: 18rpx;
}

.workorder-doc-corner-bl {
  left: 8rpx;
  bottom: 8rpx;
  border-left: 5rpx solid rgba(34, 197, 213, 0.92);
  border-bottom: 5rpx solid rgba(34, 197, 213, 0.92);
  border-bottom-left-radius: 18rpx;
}

.workorder-doc-corner-br {
  right: 8rpx;
  bottom: 8rpx;
  border-right: 5rpx solid rgba(59, 130, 246, 0.92);
  border-bottom: 5rpx solid rgba(59, 130, 246, 0.92);
  border-bottom-right-radius: 18rpx;
}

.workorder-doc-body {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 88rpx;
  height: 110rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.95) 0%, rgba(243, 249, 255, 0.92) 100%);
  border: 4rpx solid rgba(59, 130, 246, 0.88);
  box-shadow:
    0 8rpx 16rpx rgba(59, 130, 246, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
  z-index: 3;
  overflow: hidden;
}

.workorder-doc-header {
  position: absolute;
  left: 50%;
  top: 16rpx;
  transform: translateX(-50%);
  width: 72rpx;
  height: 12rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.85), rgba(34, 197, 213, 0.75));
  box-shadow: 0 2rpx 6rpx rgba(59, 130, 246, 0.15);
  z-index: 4;
}

.workorder-doc-lines {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 60rpx;
  z-index: 4;
}

.workorder-doc-line {
  height: 5rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.4), rgba(59, 130, 246, 0.25));
}

.workorder-doc-line-1 {
  width: 50rpx;
}

.workorder-doc-line-2 {
  width: 40rpx;
}

.workorder-doc-line-3 {
  width: 56rpx;
}

.workorder-doc-dots {
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  transform: translateX(-50%);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  width: 48rpx;
  z-index: 2;
  opacity: 0.5;
}

.workorder-doc-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.6), rgba(59, 130, 246, 0.4));
}

/* 优化工单卡片样式 */
.workorder-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.workorder-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 优化工单标题 */
.workorder-title-wrap {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}

.workorder-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
}

/* 优化状态标签 */
.badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}

.badge.pending {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  color: #92400E;
}

.badge.processing {
  background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
  color: #1E40AF;
}

.badge.closed {
  background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
  color: #065F46;
}

/* 优化元数据网格 */
.workorder-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F1F5F9;
}

.workorder-meta-grid .label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 4rpx;
}

.workorder-meta-grid .value {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.workorder-small {
  font-size: 24rpx;
  color: #475569;
}

/* 优化元数据行 */
.meta-inline {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-item {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #64748B;
}

/* 优化Hero区域 */
.workorders-hero-top {
  align-items: flex-start;
  margin-top: 14rpx;
}

.workorders-create-btn {
  min-width: 120rpx;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 优化KPI丝带 */
.workorder-kpi-ribbon {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 12rpx;
}

/* 优化空状态 */
.empty {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

/* 优化chip行 */
.chip-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
}

.chip {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #F1F5F9;
  color: #64748B;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.chip-active {
  background: linear-gradient(135deg, #8B5CF6, #7C3AED);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.25);
}
