<view class="page-shell">
  <view class="page-body">
    <view class="hero-card hero-lilac section">
      <view class="hero-layout">
        <view class="hero-copy">
          <view class="hero-title">{{texts.title}}</view>
          <view class="hero-desc">{{texts.desc}}</view>
          <view class="kpi-ribbon workorder-kpi-ribbon">
            <view class="kpi-chip">
              <view class="kpi-code">ALL</view>
              <view class="kpi-value">{{orders.length}}</view>
            </view>
            <view class="kpi-chip">
              <view class="kpi-code">TAB</view>
              <view class="kpi-value">{{currentStatus === 'all' ? 'A' : currentStatus === 'pending' ? 'P' : currentStatus === 'processing' ? 'R' : 'C'}}</view>
            </view>
          </view>
        </view>
        <view class="hero-visual">
          <view class="hero-scene-grid hero-scene-grid-h"></view>
          <view class="hero-scene-grid hero-scene-grid-v"></view>
          <view class="hero-scene-glow workorder-scene-glow-a"></view>
          <view class="hero-scene-glow workorder-scene-glow-b"></view>
          <view class="workorder-flow-card workorder-flow-card-back"></view>
          <view class="workorder-flow-card workorder-flow-card-mid"></view>
          <view class="workorder-flow-card workorder-flow-card-front">
            <view class="workorder-flow-topbar"></view>
            <view class="workorder-flow-status"></view>
            <view class="workorder-flow-step workorder-flow-step-a">
              <view class="workorder-flow-node"></view>
              <view class="workorder-flow-line"></view>
              <view class="workorder-flow-chip"></view>
            </view>
            <view class="workorder-flow-step workorder-flow-step-b">
              <view class="workorder-flow-node workorder-flow-node-soft"></view>
              <view class="workorder-flow-line workorder-flow-line-short"></view>
              <view class="workorder-flow-chip workorder-flow-chip-wide"></view>
            </view>
            <view class="workorder-flow-step workorder-flow-step-c">
              <view class="workorder-flow-dot"></view>
              <view class="workorder-flow-chip workorder-flow-chip-mid"></view>
              <view class="workorder-flow-chip workorder-flow-chip-short"></view>
            </view>
          </view>
          <view class="workorder-float workorder-float-a">
            <view class="workorder-float-core"></view>
          </view>
          <view class="workorder-float workorder-float-b"></view>
          <view class="workorder-float-pill workorder-float-pill-a"></view>
          <view class="workorder-float-pill workorder-float-pill-b"></view>
          <view class="workorder-curve workorder-curve-a"></view>
          <view class="workorder-curve workorder-curve-b"></view>
          <view class="workorder-curve-dot workorder-curve-dot-a"></view>
          <view class="workorder-curve-dot workorder-curve-dot-b"></view>
        </view>
      </view>
      <view class="workorders-actions">
        <view class="workorders-workflow">
          <view class="mini-code">{{texts.workflow}}</view>
        </view>
        <button class="workorders-create-btn" wx:if="{{canCreate}}" bindtap="createOrder">{{texts.create}}</button>
      </view>
    </view>

    <view class="section">
      <view class="chip-row">
        <block wx:for="{{statusTabs}}" wx:key="key">
          <view class="chip {{currentStatus === item.key ? 'chip-active' : ''}}" data-status="{{item.key}}" bindtap="onChangeStatus">{{item.name}}</view>
        </block>
      </view>
    </view>

    <view class="section">
      <view class="list" wx:if="{{orders.length}}">
        <block wx:for="{{orders}}" wx:key="workOrderId">
          <view class="card workorder-card" data-id="{{item.workOrderNum || item.workOrderId}}" data-index="{{index}}" bindtap="openDetail">
            <view class="row-between">
              <view class="art-row workorder-title-wrap">
                <view class="art-pill art-pill-line"></view>
                <view class="workorder-title">{{item.title}}</view>
              </view>
              <view class="badge {{item.statusMeta.className}}">{{item.statusMeta.text}}</view>
            </view>
            <view class="meta-inline">
              <text class="meta-item">{{item.deviceName}}</text>
              <text class="meta-item">{{item.priorityLabel}}</text>
            </view>
            <view class="workorder-meta-grid">
              <view>
                <view class="label">{{texts.time}}</view>
                <view class="value workorder-small">{{item.createdAt}}</view>
              </view>
              <view>
                <view class="label">{{texts.by}}</view>
                <view class="value workorder-small">{{item.creatorName}}</view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="empty" wx:else>{{texts.empty}}</view>
    </view>
  </view>
</view>
