.home-hero-top {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 16rpx;
  align-items: stretch;
}

.hero-kicker-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.hero-tenant-chip {
  min-height: 40rpx;
  padding: 0 14rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(191, 219, 254, 0.72);
  color: #4d678a;
  font-size: 20rpx;
}

.home-hero-title {
  max-width: 420rpx;
}

.home-hero-title-medium {
  max-width: 420rpx;
  color: #10243f;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.home-hero-title-large {
  max-width: 420rpx;
  color: #10243f;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
  margin-top: 8rpx;
}

.home-hero-desc {
  max-width: 420rpx;
}

.home-hero-desc-small {
  color: #5f748f;
  font-size: 20rpx;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.hero-status-card,
.hero-message-card {
  min-height: 108rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.hero-status-card {
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(191, 219, 254, 0.74);
  box-shadow:
    0 12rpx 24rpx rgba(15, 23, 42, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.66);
}

.hero-status-card .mini-code {
  color: #6b86a7;
}

.hero-status-value {
  color: #10243f;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
}

.hero-message-card {
  width: 100%;
  max-width: none;
  min-width: 0;
  padding-right: 18rpx;
  justify-content: flex-start;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(191, 219, 254, 0.8);
  box-shadow:
    0 12rpx 24rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  justify-self: stretch;
}

.hero-message-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.hero-message-card .mini-code {
  color: #6480a2;
}

.hero-message-value {
  color: #10243f;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
}

.home-banner-main {
  flex: 1;
  min-width: 0;
}

.home-banner-card {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.ai-entry-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 214rpx;
  gap: 14rpx;
  min-height: 196rpx;
  padding: 18rpx 20rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 12% 20%, rgba(96, 165, 250, 0.16), transparent 30%),
    radial-gradient(circle at 78% 18%, rgba(34, 197, 213, 0.12), transparent 24%),
    linear-gradient(140deg, rgba(255, 255, 255, 0.99) 0%, rgba(239, 247, 255, 0.98) 56%, rgba(240, 252, 249, 0.96) 100%);
  border: 1rpx solid rgba(186, 230, 253, 0.88);
  box-shadow:
    0 18rpx 34rpx rgba(59, 130, 246, 0.08),
    0 4rpx 12rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
  overflow: hidden;
  align-items: stretch;
}

.ai-entry-copy {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
  align-items: flex-start;
}

.ai-entry-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  width: 100%;
}

.ai-entry-title {
  margin-top: 0;
  font-size: 26rpx;
  line-height: 1.2;
}

.ai-entry-desc {
  max-width: 340rpx;
  font-size: 19rpx;
  line-height: 1.45;
}

.ai-entry-btn {
  width: 216rpx;
  min-height: 78rpx;
  margin-left: 0;
  padding: 0 22rpx 0 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  align-self: flex-start;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(96, 165, 250, 0.16);
  color: #2563eb;
  border: 1rpx solid rgba(147, 197, 253, 0.88);
  box-shadow:
    0 10rpx 18rpx rgba(59, 130, 246, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  text-align: left;
}

.ai-entry-btn::after {
  display: none;
}

.ai-entry-btn::before {
  display: none;
}

.ai-entry-btn-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(219, 234, 254, 0.48));
  border: 1rpx solid rgba(147, 197, 253, 0.6);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86),
    0 4rpx 10rpx rgba(59, 130, 246, 0.08);
  position: relative;
  flex-shrink: 0;
}

.ai-entry-btn-icon-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.9), rgba(34, 197, 213, 0.72));
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.08);
}

.ai-entry-btn-text {
  color: #2563eb;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.ai-entry-visual {
  position: relative;
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(248, 252, 255, 0.82), rgba(236, 247, 255, 0.72)),
    radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.08), transparent 52%);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    inset 0 0 0 1rpx rgba(191, 219, 254, 0.2);
  overflow: hidden;
}

.ai-orbit,
.ai-wave,
.ai-grid,
.ai-glow,
.ai-brain-shell,
.ai-brain-side,
.ai-brain-lobe,
.ai-brain-groove,
.ai-brain-core-line,
.ai-brain-stem,
.ai-neuron,
.ai-neural-link,
.ai-trace,
.ai-data-panel {
  position: absolute;
}

.ai-grid {
  opacity: 0.55;
}

.ai-grid-h {
  left: 20rpx;
  right: 20rpx;
  top: 32rpx;
  bottom: 32rpx;
  background:
    linear-gradient(rgba(148, 163, 184, 0.08) 2rpx, transparent 2rpx);
  background-size: 100% 34rpx;
}

.ai-grid-v {
  top: 20rpx;
  bottom: 20rpx;
  left: 34rpx;
  right: 34rpx;
  background:
    linear-gradient(90deg, rgba(148, 163, 184, 0.06) 2rpx, transparent 2rpx);
  background-size: 36rpx 100%;
}

.ai-glow {
  border-radius: 50%;
  filter: blur(6rpx);
}

.ai-glow-a {
  width: 120rpx;
  height: 120rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(59, 130, 246, 0.24), rgba(59, 130, 246, 0.04) 62%, transparent 72%);
}

.ai-glow-b {
  width: 76rpx;
  height: 76rpx;
  right: 32rpx;
  top: 30rpx;
  background: radial-gradient(circle, rgba(34, 197, 213, 0.2), transparent 72%);
}

.ai-brain-shell {
  left: 50%;
  top: 50%;
  width: 154rpx;
  height: 126rpx;
  transform: translate(-50%, -50%);
  filter: drop-shadow(0 16rpx 22rpx rgba(59, 130, 246, 0.1));
}

.ai-brain-side {
  top: 0;
  width: 72rpx;
  height: 100rpx;
}

.ai-brain-left {
  left: 0;
}

.ai-brain-right {
  right: 0;
  transform: scaleX(-1);
}

.ai-brain-lobe {
  position: absolute;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(229, 242, 255, 0.88));
  border: 1rpx solid rgba(147, 197, 253, 0.62);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 8rpx 18rpx rgba(59, 130, 246, 0.08);
}

.ai-brain-lobe-a {
  left: 8rpx;
  top: 8rpx;
  width: 46rpx;
  height: 44rpx;
  border-radius: 32rpx 28rpx 20rpx 28rpx;
}

.ai-brain-lobe-b {
  left: 4rpx;
  top: 42rpx;
  width: 52rpx;
  height: 40rpx;
  border-radius: 28rpx 24rpx 26rpx 30rpx;
}

.ai-brain-lobe-c {
  left: 26rpx;
  top: 20rpx;
  width: 36rpx;
  height: 50rpx;
  border-radius: 24rpx 28rpx 22rpx 26rpx;
}

.ai-brain-groove {
  position: absolute;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.22), rgba(34, 197, 213, 0.12));
}

.ai-brain-groove-a {
  left: 18rpx;
  top: 20rpx;
  width: 6rpx;
  height: 46rpx;
}

.ai-brain-groove-b {
  left: 32rpx;
  top: 14rpx;
  width: 6rpx;
  height: 58rpx;
}

.ai-brain-groove-c {
  left: 46rpx;
  top: 24rpx;
  width: 5rpx;
  height: 38rpx;
}

.ai-brain-core-line {
  left: 50%;
  top: 10rpx;
  bottom: 18rpx;
  width: 4rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(191, 219, 254, 0.2), rgba(59, 130, 246, 0.42), rgba(191, 219, 254, 0.18));
}

.ai-brain-stem {
  left: 50%;
  bottom: 0;
  width: 22rpx;
  height: 34rpx;
  transform: translateX(-50%);
  border-radius: 0 0 16rpx 16rpx;
  background: linear-gradient(180deg, rgba(219, 234, 254, 0.92), rgba(191, 219, 254, 0.72));
  border: 1rpx solid rgba(147, 197, 253, 0.52);
}

.ai-neuron {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.94);
  box-shadow:
    0 0 0 8rpx rgba(59, 130, 246, 0.08),
    0 4rpx 12rpx rgba(59, 130, 246, 0.08);
}

.ai-neuron-a {
  right: 34rpx;
  top: 40rpx;
}

.ai-neuron-b {
  left: 32rpx;
  bottom: 56rpx;
}

.ai-neuron-c {
  right: 48rpx;
  bottom: 34rpx;
}

.ai-neuron-d {
  left: 52rpx;
  top: 28rpx;
}

.ai-neural-link {
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.04), rgba(34, 197, 213, 0.66), rgba(59, 130, 246, 0.04));
  box-shadow: 0 0 12rpx rgba(34, 197, 213, 0.12);
}

.ai-neural-link-a {
  left: 98rpx;
  top: 76rpx;
  width: 74rpx;
  transform: rotate(-18deg);
}

.ai-neural-link-b {
  left: 30rpx;
  bottom: 74rpx;
  width: 78rpx;
  transform: rotate(18deg);
}

.ai-neural-link-c {
  left: 108rpx;
  bottom: 52rpx;
  width: 60rpx;
  transform: rotate(28deg);
}

.ai-trace {
  height: 2rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.08), rgba(59, 130, 246, 0.42));
}

.ai-trace::after {
  content: "";
  position: absolute;
  right: -4rpx;
  top: 50%;
  width: 8rpx;
  height: 8rpx;
  transform: translateY(-50%);
  border-radius: 50%;
  background: rgba(59, 130, 246, 0.7);
  box-shadow: 0 0 10rpx rgba(59, 130, 246, 0.18);
}

.ai-trace-a {
  left: 18rpx;
  top: 52rpx;
  width: 46rpx;
}

.ai-trace-b {
  left: 30rpx;
  bottom: 44rpx;
  width: 62rpx;
  background: linear-gradient(90deg, rgba(34, 197, 213, 0.08), rgba(34, 197, 213, 0.46));
}

.ai-trace-b::after {
  background: rgba(34, 197, 213, 0.72);
  box-shadow: 0 0 10rpx rgba(34, 197, 213, 0.2);
}

.ai-trace-c {
  right: 20rpx;
  bottom: 82rpx;
  width: 42rpx;
}

.ai-data-panel {
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(191, 219, 254, 0.74);
  box-shadow:
    0 10rpx 18rpx rgba(15, 23, 42, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.ai-data-panel-a {
  left: 14rpx;
  top: 18rpx;
  width: 66rpx;
  padding: 10rpx 10rpx 8rpx;
}

.ai-data-panel-b {
  right: 14rpx;
  bottom: 18rpx;
  width: 72rpx;
  height: 52rpx;
}

.ai-data-code {
  color: #5d7595;
  font-size: 14rpx;
  letter-spacing: 1.8rpx;
}

.ai-data-bars {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.ai-data-bars view {
  width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.9), rgba(34, 197, 213, 0.42));
}

.ai-data-chip {
  position: absolute;
  left: 12rpx;
  top: 12rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.9), rgba(34, 197, 213, 0.82));
}

.ai-data-line {
  position: absolute;
  left: 38rpx;
  right: 10rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.3);
}

.ai-data-line-a {
  top: 16rpx;
}

.ai-data-line-b {
  top: 28rpx;
  right: 20rpx;
  background: rgba(34, 197, 213, 0.34);
}

.ai-wave {
  left: 26rpx;
  right: 26rpx;
  bottom: 14rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(34, 197, 213, 0.22);
  border-color: rgba(34, 197, 213, 0.28) transparent transparent transparent;
}

.home-feed-title {
  flex: 1;
  min-width: 0;
  padding-right: 10rpx;
}

.feed-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.feed-card {
  min-height: 202rpx;
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  border-radius: 26rpx;
  overflow: hidden;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.98) 0%, rgba(241, 248, 255, 0.98) 52%, rgba(236, 253, 247, 0.98) 100%);
  border: 1rpx solid rgba(186, 230, 253, 0.72);
  box-shadow:
    0 14rpx 28rpx rgba(15, 23, 42, 0.05),
    0 3rpx 10rpx rgba(15, 23, 42, 0.03);
}

.feed-visual {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.36);
}

.feed-copy {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.feed-topline {
  align-items: flex-start;
}

.feed-title {
  margin-top: 8rpx;
  line-height: 1.4;
}

.feed-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feed-system-ring,
.feed-system-core,
.feed-order-sheet,
.feed-alert-triangle,
.feed-alert-line,
.feed-alert-dot {
  position: absolute;
}

.feed-system-ring {
  left: 50%;
  top: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.feed-system-ring-a {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(59, 130, 246, 0.28);
}

.feed-system-ring-b {
  width: 96rpx;
  height: 96rpx;
  border: 3rpx dashed rgba(34, 197, 213, 0.2);
}

.feed-system-core {
  left: 50%;
  top: 50%;
  width: 26rpx;
  height: 26rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.94), rgba(34, 197, 213, 0.86));
}

.feed-order-sheet {
  border-radius: 16rpx;
}

.feed-order-sheet-back {
  left: 24rpx;
  top: 42rpx;
  width: 56rpx;
  height: 74rpx;
  background: rgba(59, 130, 246, 0.12);
  transform: rotate(-8deg);
}

.feed-order-sheet-front {
  left: 42rpx;
  top: 30rpx;
  width: 66rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(191, 219, 254, 0.72);
}

.feed-order-line {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: rgba(59, 130, 246, 0.32);
}

.feed-order-line-a {
  top: 20rpx;
}

.feed-order-line-b {
  top: 38rpx;
  background: rgba(34, 197, 213, 0.28);
}

.feed-order-line-c {
  top: 56rpx;
}

.feed-alert-triangle {
  left: 50%;
  top: 44%;
  width: 0;
  height: 0;
  transform: translate(-50%, -50%);
  border-left: 38rpx solid transparent;
  border-right: 38rpx solid transparent;
  border-bottom: 68rpx solid rgba(59, 130, 246, 0.18);
}

.feed-alert-line {
  left: 50%;
  top: 44%;
  width: 6rpx;
  height: 30rpx;
  transform: translate(-50%, -50%);
  border-radius: 999rpx;
  background: rgba(34, 197, 213, 0.92);
}

.feed-alert-dot {
  left: 50%;
  top: 66%;
  width: 8rpx;
  height: 8rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: rgba(34, 197, 213, 0.92);
}

.hero-visual-card {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.12), transparent 50%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.85) 0%, rgba(241, 248, 255, 0.88) 58%, rgba(235, 253, 248, 0.85) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-visual-core,
.hero-visual-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
}

.hero-visual-core {
  width: 20rpx;
  height: 20rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.95), rgba(34, 197, 213, 0.92));
  box-shadow: 0 0 0 6rpx rgba(59, 130, 246, 0.1);
  z-index: 3;
}

.hero-visual-ring {
  border: 2rpx solid rgba(59, 130, 246, 0.25);
  z-index: 2;
}

.hero-visual-ring-a {
  width: 52rpx;
  height: 52rpx;
}

.hero-visual-ring-b {
  width: 76rpx;
  height: 76rpx;
  border-color: rgba(34, 197, 213, 0.18);
}

.hero-visual-bar {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  z-index: 2;
}

.hero-visual-bar view {
  width: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.92), rgba(34, 197, 213, 0.5));
}

.home-matrix-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
}

.matrix-card {
  min-height: 218rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 22rpx;
}

.matrix-scene {
  position: relative;
  min-height: 218rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.matrix-aura,
.matrix-grain {
  position: absolute;
  inset: 0;
}

.matrix-grain {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 42%),
    linear-gradient(225deg, rgba(255, 255, 255, 0.1), transparent 38%);
}

.matrix-meta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 14rpx;
  z-index: 5;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 16rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.matrix-caption {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.matrix-label {
  color: #183153;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 12rpx rgba(255, 255, 255, 0.55);
}

.matrix-scan .matrix-scene {
  background: linear-gradient(145deg, #edf7ff 0%, #f5fbff 44%, #ebfbf6 100%);
