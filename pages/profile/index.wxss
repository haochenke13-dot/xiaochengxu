/* 个人中心页UI优化 */

/* 简约蓝色用户图标 */
.user-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
}

.user-circle {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3B82F6, #0EA5E9);
  border-radius: 50%;
  box-shadow:
    0 8rpx 32rpx rgba(14, 165, 233, 0.3),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.15);
}

.user-circle::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.user-head-simple {
  position: absolute;
  left: 50%;
  top: 35%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 0 rgba(14, 165, 233, 0.1);
  z-index: 2;
}

.user-body-simple {
  position: absolute;
  left: 50%;
  bottom: 25%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx 32rpx 16rpx 16rpx;
  box-shadow:
    0 4rpx 12rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 0 rgba(14, 165, 233, 0.1);
  z-index: 1;
}

.user-glow {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  height: 140rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.2), transparent 70%);
  border-radius: 50%;
  animation: glow-pulse 3s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%, 100% {
    opacity: 0.6;
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    opacity: 0.3;
    transform: translate(-50%, -50%) scale(1.1);
  }
}

page {
  background: #f4f8fb;
}

/* 优化用户信息卡片 */
.user-info-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.user-role {
  font-size: 24rpx;
  color: #64748B;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.role-badge {
  padding: 4rpx 12rpx;
  background: #F1F5F9;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #475569;
}

/* 优化菜单列表 */
.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
  transition: background 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8FAFC;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon.settings {
  background: linear-gradient(135deg, #DBEAFE, #BFDBFE);
}

.menu-icon.feedback {
  background: linear-gradient(135deg, #EDE9FE, #DDD6FE);
}

.menu-icon.about {
  background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #94A3B8;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #CBD5E1;
}

/* 优化退出按钮 */
.logout-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #EF4444;
  color: #EF4444;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.1);
}

.logout-btn:active {
  background: #FEF2F2;
}

/* 优化版本信息 */
.version-info {
  text-align: center;
  padding: 32rpx;
  font-size: 22rpx;
  color: #CBD5E1;
}
