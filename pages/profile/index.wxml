<view class="page-shell">
  <view class="page-body">
    <view class="hero-card hero-lilac section">
      <view class="hero-layout">
        <view class="hero-copy">
          <view class="hero-title">{{profile.name}}</view>
          <view class="hero-desc">{{roleMeta.name}} · {{profile.employeeNo}}</view>
        </view>
        <view class="hero-visual">
          <view class="hero-scene-grid hero-scene-grid-h"></view>
          <view class="hero-scene-grid hero-scene-grid-v"></view>
          <view class="hero-scene-glow profile-scene-glow-a"></view>
          <view class="hero-scene-glow profile-scene-glow-b"></view>
          <view class="profile-link profile-link-a"></view>
          <view class="profile-link profile-link-b"></view>
          <view class="profile-link profile-link-c"></view>
          <view class="profile-node profile-node-a"></view>
          <view class="profile-node profile-node-b"></view>
          <view class="profile-node profile-node-c"></view>
          <view class="profile-id-card">
            <view class="profile-id-topbar"></view>
            <view class="profile-avatar-shell">
              <view class="profile-avatar-ring"></view>
              <view class="profile-avatar-head"></view>
              <view class="profile-avatar-body"></view>
            </view>
            <view class="profile-card-line profile-card-line-a"></view>
            <view class="profile-card-line profile-card-line-b"></view>
            <view class="profile-card-line profile-card-line-c"></view>
            <view class="profile-card-chip profile-card-chip-a"></view>
            <view class="profile-card-chip profile-card-chip-b"></view>
          </view>
          <view class="profile-badge profile-badge-a"></view>
          <view class="profile-badge profile-badge-b">
            <view class="profile-badge-core"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="stat-grid">
        <block wx:for="{{stats}}" wx:key="label">
          <view class="stat-card">
            <view class="stat-value">{{item.value}}</view>
            <view class="stat-label">{{item.label}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text>{{texts.role}}</text>
      </view>
      <view class="chip-row">
        <block wx:for="{{roleOptions}}" wx:key="code">
          <view class="chip {{profile.roleCode === item.code ? 'chip-active' : ''}}" data-role="{{item.code}}" bindtap="onSwitchRole">{{item.name}}</view>
        </block>
      </view>
    </view>

    <view class="section" wx:if="{{adminMenus.length}}">
      <view class="section-title">
        <text>{{texts.admin}}</text>
      </view>
      <view class="card">
        <view class="menu-list">
          <block wx:for="{{adminMenus}}" wx:key="key">
            <view class="menu-item menu-button" data-key="{{item.key}}" bindtap="onMenuTap">
              <view class="art-row">
                <view class="menu-glyph menu-glyph-{{item.key}}"></view>
                <view>
                  <view class="mini-title">{{item.title}}</view>
                  <view class="mini-desc">{{item.desc}}</view>
                </view>
              </view>
              <text class="text-link">{{texts.enter}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text>{{texts.flow}}</text>
      </view>
      <view class="card">
        <view class="menu-list">
          <block wx:for="{{businessMenus}}" wx:key="key">
            <view class="menu-item menu-button" data-key="{{item.key}}" bindtap="onMenuTap">
              <view class="art-row">
                <view class="menu-glyph menu-glyph-{{item.key}}"></view>
                <view>
                  <view class="mini-title">{{item.title}}</view>
                  <view class="mini-desc">{{item.desc}}</view>
                </view>
              </view>
              <text class="text-link">{{texts.enter}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text>{{texts.system}}</text>
      </view>
      <view class="card">
        <view class="menu-list">
          <block wx:for="{{systemMenus}}" wx:key="key">
            <view class="menu-item menu-button" data-key="{{item.key}}" bindtap="onMenuTap">
              <view class="art-row">
                <view class="menu-glyph menu-glyph-{{item.key}}"></view>
                <view>
                  <view class="mini-title">{{item.title}}</view>
                  <view class="mini-desc">{{item.desc}}</view>
                </view>
              </view>
              <text class="text-link">{{texts.enter}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>
