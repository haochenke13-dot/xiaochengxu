/* 购物车页面样式 */

.cart-page {
  min-height: 100vh;
  background: #F8FAFC;
  padding-bottom: 180rpx;
}

/* 头部 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
}

.clear-btn {
  font-size: 28rpx;
  color: #EF4444;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #FEE2E2;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #64748B;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94A3B8;
  margin-bottom: 48rpx;
}

.continue-btn {
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 64rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.continue-btn::after {
  border: none;
}

/* 购物车列表 */
.cart-list {
  padding: 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.item-image-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #F8FAFC, #F1F5F9);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-emoji {
  font-size: 60rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-spec {
  font-size: 24rpx;
  color: #94A3B8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #0EA5E9;
}

.item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.qty-btn:active {
  transform: scale(0.9);
}

.qty-icon {
  font-size: 32rpx;
  font-weight: bold;
  color: #0EA5E9;
  line-height: 1;
}

.qty-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  min-width: 48rpx;
  text-align: center;
}

.item-total {
  text-align: right;
}

.total-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.cart-item:active .delete-btn {
  opacity: 1;
}

.delete-icon {
  font-size: 32rpx;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  padding: 24rpx;
  border-top: 1rpx solid #E2E8F0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.footer-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.total-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.count-label {
  font-size: 24rpx;
  color: #64748B;
}

.count-number {
  font-size: 28rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 24rpx;
  color: #64748B;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #EF4444;
}

.submit-btn {
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(14, 165, 233, 0.2);
}
