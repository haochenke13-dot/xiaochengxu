/* 设置页UI优化 */

page {
  background: #f4f8fb;
}

/* 优化设置卡片 */
.settings-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 优化设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.setting-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.setting-item:first-child {
  padding-top: 0;
}

.setting-info {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 6rpx;
}

.setting-desc {
  font-size: 22rpx;
  color: #94A3B8;
  line-height: 1.4;
}

/* 优化开关控件 */
.switch-control {
  position: relative;
  width: 88rpx;
  height: 48rpx;
  background: #E2E8F0;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.switch-control.active {
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
}

.switch-control::after {
  content: '';
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.switch-control.active::after {
  left: 44rpx;
}

/* 优化语言选择器 */
.language-selector {
  display: flex;
  gap: 12rpx;
}

.language-option {
  flex: 1;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #F1F5F9;
  border: 2rpx solid transparent;
  text-align: center;
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
  transition: all 0.3s ease;
}

.language-option.active {
  background: linear-gradient(135deg, #0EA5E9, #3B82F6);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.25);
}

/* 优化保存按钮 */
.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 优化设置分组 */
.settings-group {
  margin-bottom: 24rpx;
}

.settings-group-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #94A3B8;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

/* 优化提示信息 */
.tip-box {
  padding: 16rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  border-left: 4rpx solid #F59E0B;
  margin-top: 16rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #92400E;
  line-height: 1.5;
}
